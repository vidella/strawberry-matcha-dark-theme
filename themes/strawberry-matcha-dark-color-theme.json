	"tokenColors": [
		{
			"scope": [
				"comment",
				"punctuation.definition.comment"
			],
			"settings": {
				"foreground": "#7D8970",
				"fontStyle": "italic"
			}
		},
		{
			"scope": [
				"keyword",
				"storage.type",
				"storage.modifier"
			],
			"settings": {
				"foreground": "#D5E3EE",
				"fontStyle": "bold"
			}
		},
		{
			"scope": [
				"string",
				"meta.embedded.assembly"
			],
			"settings": {
				"foreground": "#DBE9CA"
			}
		},
		{
			"scope": [
				"constant.numeric",
				"constant.language.boolean",
				"constant.language.null"
			],
			"settings": {
				"foreground": "#F5E7A1"
			}
		},
		{
			"scope": [
				"entity.name.function",
				"support.function"
			],
			"settings": {
				"foreground": "#f4d4e0"
			}
		},
		{
			"scope": [
				"variable",
				"support.variable"
			],
			"settings": {
				"foreground": "#D8C7F4"
			}
		},
		{
			"scope": [
				"entity.name.type",
				"support.type",
				"entity.name.class"
			],
			"settings": {
				"foreground": "#B7E4D4"
			}
		},
		{
			"scope": [
				"meta.object-literal.key",
				"support.type.property-name",
				"variable.other.property"
			],
			"settings": {
				"foreground": "#D5E3EE"
			}
		},
		{
			"scope": [
				"punctuation",
				"meta.brace",
				"meta.delimiter"
			],
			"settings": {
				"foreground": "#F5E7A1"
			}
		},
		{
			"scope": [
				"entity.name.tag"
			],
			"settings": {
				"foreground": "#DBE9CA"
			}
		},
		{
			"scope": [
				"entity.other.attribute-name"
			],
			"settings": {
				"foreground": "#f4d4e0"
			}
		},
		{
			"scope": "token.info-token",
			"settings": {
				"foreground": "#6796E6"
			}
		},
		{
			"scope": "token.warn-token",
			"settings": {
				"foreground": "#CD9731"
			}
		},
		{
			"scope": "token.error-token",
			"settings": {
				"foreground": "#F44747"
			}
		},
		{
			"scope": "token.debug-token",
			"settings": {
				"foreground": "#B267E6"
			}
		}
	]
}