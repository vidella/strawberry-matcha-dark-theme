				"punctuation.definition.annotation",
				"meta.annotation",
				"entity.name.type.annotation",
				"meta.decorator",
				"meta.decorator.ts",
				"meta.decorator.tsx"
			],
			"settings": {
				"foreground": "#B46E8D"
			}
		},
		{
			"scope": [
				"keyword.operator",
				"keyword.operator.assignment",
				"keyword.operator.comparison",
				"keyword.operator.logical",
				"keyword.operator.expression",
				"keyword.operator.expression.typeof",
				"keyword.operator.expression.instanceof",
				"keyword.operator.new"
			],
			"settings": {
				"foreground": "#FEFCFC"
			}
		},
		{
			"scope": [
				"support.type.property-name.json",
				"support.type.property-name.json.comments",
				"source.json support.type.property-name.json",
				"source.json support.type.property-name.json.comments",
				"meta.structure.dictionary.json support.type.property-name.json",
				"meta.structure.dictionary.json.comments support.type.property-name.json.comments"
			],
			"settings": {
				"foreground": "#CB6B91"
			}
		},
		{
			"scope": [
				"punctuation.support.type.property-name.begin.json",
				"punctuation.support.type.property-name.end.json",
				"punctuation.support.type.property-name.begin.json.comments",
				"punctuation.support.type.property-name.end.json.comments"
			],
			"settings": {
				"foreground": "#CB6B91"
			}
		},
		{
			"scope": [
				"support.constant.property-value.css",
				"constant.other.color.rgb-value.css",
