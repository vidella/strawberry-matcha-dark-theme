				"variable.other.property.tsx",
				"variable.other.object.property.ts",
				"variable.other.object.property.tsx",
				"variable.other.object.property.java",
				"variable.other.property.java",
				"variable.other.member.java",
				"entity.name.variable.field.java"
			],
			"settings": {
				"foreground": "#CB6B91"
			}
		},
		{
			"scope": [
				"variable.other.global",
				"variable.other.global.ts",
				"variable.other.global.tsx"
			],
			"settings": {
				"foreground": "#618C71"
