	"tokenColors": [
		{
			"scope": [
				"source",
				"text"
			],
			"settings": {
				"foreground": "#FEFCFC"
			}
		},
		{
			"scope": [
				"comment",
				"punctuation.definition.comment"
			],
			"settings": {
				"foreground": "#7F8D78",
				"fontStyle": "italic"
			}
		},
		{
			"scope": [
				"keyword",
				"storage.type",
				"storage.modifier",
				"storage.type.class",
				"storage.type.interface",
				"storage.type.function",
				"storage.type.const",
				"storage.type.let",
				"storage.type.var"
			],
			"settings": {
				"foreground": "#98556C",
				"fontStyle": "bold"
			}
		},
		{
			"scope": [
				"string",
				"punctuation.definition.string",
				"string.template",
				"string.quoted",
				"string.quoted.single",
				"string.quoted.double"
			],
			"settings": {
				"foreground": "#AEC09B"
			}
		},
		{
			"scope": [
				"entity.name.function.java",
				"meta.method.identifier.java",
				"meta.method.declaration.java entity.name.function.java"
			],
			"settings": {
				"foreground": "#FEFCFC"
			}
		},
		{
			"scope": [
				"constant.numeric",
				"constant.language",
				"constant.character",
				"constant.other",
				"constant.language.boolean",
				"constant.language.null",
				"constant.language.undefined"
			],
			"settings": {
				"foreground": "#AEC09B"
			}
		},
		{
			"scope": [
				"entity.name.function",
				"support.function",
				"meta.function-call",
				"variable.function",
				"entity.name.function.ts",
				"entity.name.function.tsx",
				"meta.method.declaration.ts entity.name.function",
				"meta.method.declaration.tsx entity.name.function"
			],
			"settings": {
				"foreground": "#FEFCFC"
			}
		},
		{
			"scope": [
				"entity.name.type",
				"entity.name.class",
				"entity.name.interface",
				"entity.name.struct",
				"entity.name.enum",
				"support.type",
				"support.class",
				"support.type.primitive.ts",
				"support.type.builtin.ts",
				"entity.name.type.class.ts",
				"entity.name.type.interface.ts",
				"entity.name.type.alias.ts"
			],
			"settings": {
				"foreground": "#FEFCFC"
			}
		},
		{
			"scope": [
				"variable.parameter",
				"meta.parameter",
				"variable.parameter.ts",
				"variable.parameter.tsx"
			],
			"settings": {
				"foreground": "#CB6B91"
			}
		},
		{
			"scope": [
				"punctuation.separator.period.java",
				"punctuation.separator.java",
				"punctuation.accessor.java"
			],
			"settings": {
				"foreground": "#FEFCFC"
			}
		},
		{
			"scope": [
				"variable.other.readwrite",
